{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "title": "Kova",
        "width": 1400,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 14, "y": 13 }
      }
    ]
  },
  "bundle": {
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown Document",
        "description": "Markdown presentation",
        "role": "Editor"
      }
    ]
  }
}
