{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kova",
  "version": "0.2.8",
  "identifier": "md.kova.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kova",
        "width": 1400,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**"]
      },
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: asset: tauri:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://themes.kova.md; object-src 'none'; base-uri 'self'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM2QkVGOEZBMjQ4QkY1QgpSV1JidjBpaWorOXJEUDZlaEhvTjA3SGNlTUNFMnVRYmV5NjNnTGVTWCtMZElGV1lkV2kzUFRxaQo=",
      "endpoints": [
        "https://github.com/KovaMD/Kova/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "kova.desktop"
      },
      "rpm": {
        "desktopTemplate": "kova.desktop"
      }
    }
  }
}
